rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{uid}
    // Fields:
    //   - uid: string (required)
    //   - balance: number (required)
    //   - tradingPrinciples: string (optional)
    //   - updatedAt: timestamp (optional)
    //
    // Collection: /users/{uid}/holdings/{holdingId}
    // Fields:
    //   - uid: string (required)
    //   - symbol: string (required)
    //   - name: string (optional)
    //   - quantity: number (required)
    //   - averagePrice: number (optional)
    //   - updatedAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'balance']) &&
             data.uid == request.auth.uid &&
             data.balance is number &&
             (!('tradingPrinciples' in data) || data.tradingPrinciples is string);
    }

    function isValidHolding(data) {
      return data.keys().hasAll(['uid', 'symbol', 'quantity']) &&
             data.uid == request.auth.uid &&
             data.symbol is string &&
             data.quantity is number;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);

      match /holdings/{holdingId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidHolding(request.resource.data);
        allow update: if isOwner(userId) && isValidHolding(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
